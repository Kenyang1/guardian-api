PORT=3000
# Your Firebase project ID - used to verify ID tokens issued by Firebase Auth
FIREBASE_PROJECT_ID=your-firebase-project-id
# Postgres connection string (Supabase: Settings -> Database -> Connection string)
DATABASE_URL=postgresql://user:password@host:5432/postgres
# Anthropic API key for LLM merchant categorization (console.anthropic.com)
# Server-side only - never ships to a client, never enters git.
ANTHROPIC_API_KEY=your-anthropic-api-key
